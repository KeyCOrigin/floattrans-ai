{
  "name": "floattrans-ai",
  "version": "1.0.0",
  "description": "FloatTrans AI — 极简桌面双语字幕助手",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "electron:dev": "tsx electron/main.ts",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.7.0",
    "tsx": "^4.22.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0"
  }
}
