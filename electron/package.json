{
  "name": "floattrans-ai-electron",
  "version": "2.0.0",
  "description": "FloatTrans AI — 实时桌面双语字幕助手 (Electron 前端)",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "tsc -p tsconfig.electron.json && electron .",
    "dev:all": "tsc -p tsconfig.electron.json && node scripts/dev-all.mjs",
    "start": "vite build && tsc -p tsconfig.electron.json && electron .",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^41.7.0",
    "tsx": "^4.22.0",
    "typescript": "~5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
